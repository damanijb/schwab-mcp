{
  "mcpServers": {
    "schwab": {
      "command": "bun",
      "args": ["run", "${CLAUDE_PLUGIN_ROOT}/../src/index.ts"],
      "env": {
        "SCHWAB_CLIENT_ID": "${SCHWAB_CLIENT_ID}",
        "SCHWAB_CLIENT_SECRET": "${SCHWAB_CLIENT_SECRET}",
        "SCHWAB_CALLBACK_URL": "${SCHWAB_CALLBACK_URL}",
        "SCHWAB_TOKEN_PATH": "${SCHWAB_TOKEN_PATH}",
        "SCHWAB_ENABLE_TRADING": "${SCHWAB_ENABLE_TRADING}"
      }
    }
  }
}
